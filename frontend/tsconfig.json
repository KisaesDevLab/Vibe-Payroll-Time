{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "sourceMap": true,
    "noEmit": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*", "vite.config.ts"]
}
