{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "sourceMap": true,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*", "vite.config.ts"],
  "references": [{ "path": "../shared" }]
}
