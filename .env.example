## Vibe Payroll Time — environment variables
## Copy to .env and fill in. Never commit .env.
##
## Variables grouped as:
##   [dev]      used only by docker-compose.yml / local npm run dev
##   [grouped]  used only by docker-compose.grouped.yml (multi-app dev overlay)
##   [prod]     used only by docker-compose.prod.yml
##   [both]     used across modes

# ---------- Appliance (both) ----------
APPLIANCE_ID=local-dev
NODE_ENV=development
LOG_LEVEL=debug

# ---------- Backend ----------
BACKEND_PORT=4000
BACKEND_HOST=0.0.0.0

# Frontend origins allowed for CORS (dev vite server). 5180, not 5173 —
# Vibe MyBooks owns 5173 on the CPA-firm workstations that run both
# products side-by-side. Comma-separate to list multiple origins. Each
# entry may be a literal origin or a regex delimited with slashes
# (e.g. /^https:\/\/.*\.tailnet\.ts\.net$/).
#
# Phase 14 rename: CORS_ORIGIN is the deprecated old name. New
# deployments should set ALLOWED_ORIGIN. The old name still works for
# now and will be removed in a future release.
ALLOWED_ORIGIN=http://localhost:5180

# Canonical public origin embedded in outbound URLs (magic-link emails,
# payroll-export downloads, password resets). Optional — when blank,
# the first ALLOWED_ORIGIN entry is used. Set this in production so a
# request reaching the API via an internal hop (Caddy, Tailscale)
# still produces emails pointing at the customer-facing domain.
PUBLIC_URL=

# Cookie path + Secure flag — accepted but currently unused (auth uses
# bearer tokens). Set to `/payroll` + `true` in the multi-app overlay so
# a future cookie middleware lands with the right scope.
COOKIE_PATH=/
COOKIE_SECURE=false

# ---------- Database ----------
# POSTGRES_PORT is the port the host process (npm run dev) connects to,
# matching the host port the dev compose publishes (POSTGRES_PUBLISH_PORT
# below, default 5437). Inside the api container in prod this is 5432
# (the postgres service's internal listen port) — set explicitly in
# docker-compose.prod.yml so it doesn't pick this up.
POSTGRES_HOST=localhost
POSTGRES_PORT=5437
POSTGRES_USER=vibept
POSTGRES_PASSWORD=vibept_dev
POSTGRES_DB=vibept

# Host port for the dev Postgres container (docker-compose.yml). 5437 by
# convention so multiple Vibe apps' Postgres containers can run side-by-
# side on the same workstation. If you change this, change POSTGRES_PORT
# above to match.
POSTGRES_PUBLISH_PORT=5437

# Host port for pgAdmin under `--profile tools` (docker-compose.yml).
PGADMIN_PUBLISH_PORT=5052

# Full URL form, used by Knex. Mirrors POSTGRES_PORT above.
DATABASE_URL=postgres://vibept:vibept_dev@localhost:5437/vibept

# ---------- Redis / background jobs (Phase 14) ----------
# Redis backs BullMQ queues for the four background jobs (auto-clockout,
# missed-punch, license-heartbeat, retention-sweep). The dev compose
# publishes Redis on 6386 to avoid colliding with sibling Vibe apps;
# in prod the api container reaches it via the internal network.
REDIS_URL=redis://localhost:6386
REDIS_PUBLISH_PORT=6386

# Master switch — when false the scheduler and workers don't start and
# Redis is never contacted. Used by the test suite. Standalone
# customers normally leave this true.
WORKERS_ENABLED=true

# Background-job role for this process:
#   all       — schedule + consume in-process (standalone default)
#   scheduler — only enqueue (appliance api container)
#   worker    — only consume (appliance worker container; entrypoint
#               is dist/worker.js)
WORKER_ROLE=all
WORKER_CONCURRENCY=2

# ---------- Auth / crypto ----------
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-me-with-64-bytes-hex
# AES-256-GCM key for encrypting per-company Twilio/SMTP secrets at rest.
# Generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=replace-me-with-32-bytes-hex

# Phase 4.5 QR badge HMAC signing key. Optional — leave blank to derive
# from SECRETS_ENCRYPTION_KEY via HKDF. Set explicitly to rotate badges
# independently of Twilio/SMTP secrets. Rotating this invalidates every
# printed badge in the appliance; recovery is bulk-reissue.
# Generate with: openssl rand -hex 32
# BADGE_SIGNING_SECRET=

# ---------- Frontend (Vite) ----------
# Only VITE_-prefixed vars are exposed to the client.
#
# VITE_API_BASE_URL is intentionally commented out in the `frontend/.env`
# you'll copy — it defaults to the relative path `/api/v1`. That makes
# the bundled JS send API requests to the SAME origin that served the
# SPA, so opening http://<lan-ip>:5180 from a phone or tablet on the
# same wifi just works (vite's dev-server proxy forwards /api/* to the
# backend on localhost:4000 server-side).
#
# Set it to an absolute URL ONLY if the frontend is served from a
# different origin than the backend in production (most appliance
# deployments put Caddy in front of both, so you still leave it unset).
# VITE_API_BASE_URL=

# Override the dev-server's proxy target if the backend isn't on
# localhost:4000. Only read by vite.config.ts in dev; not bundled.
# VITE_DEV_BACKEND_ORIGIN=http://localhost:4000

# Vite `base` — single-app default `/`; the multi-app deployment overlay
# sets `/payroll/` so the SPA serves under the shared Caddy ingress prefix
# at https://<host>/payroll/. Affects asset URLs, the PWA manifest scope,
# and the SPA router.
VITE_BASE_PATH=/

VITE_APP_NAME=Vibe Payroll Time

# ---------- Migrations ----------
# If true, run pending migrations on backend boot.
# Phase 14 rename: MIGRATE_ON_BOOT is the deprecated old name. New
# deployments should set MIGRATIONS_AUTO. The old name still works for
# now and will be removed in a future release.
MIGRATIONS_AUTO=true

# ---------- Tenant mode (Phase 14.2) ----------
# `multi` (default for standalone) keeps today's behavior — one
# appliance hosts many companies, the create-firm flow is visible.
# `single` is for the appliance overlay — one company per appliance,
# create-firm UI hidden, the API refuses to start if the DB has more
# than one company. FIRM_NAME pre-fills the setup wizard's company
# name on first boot in single mode; ignored in multi.
TENANT_MODE=multi
FIRM_NAME=

# Run the Acme Plumbing demo seed after migrations. Idempotent (the
# seed deletes + recreates its own company) but DESTRUCTIVE to any
# edits the operator made inside the demo company. Leave off on a
# production appliance; flip on for a demo VM or fresh test install.
SEED_DEMO_ON_BOOT=false

# ---------- Production ingress (prod) ----------
# Public DNS name for the appliance. Leave empty if using a Cloudflare Tunnel
# or Tailscale Funnel sidecar — the tunnel supplies its own hostname.
APP_DOMAIN=

# ACME email used by Caddy when auto-provisioning Let's Encrypt certs for
# direct-public-internet deployments.
CADDY_ACME_EMAIL=admin@example.com

# Host ports the Caddy container binds. Only used by the `public` profile.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ---------- Cloudflare Tunnel (prod, optional) ----------
# Paste the token printed by `cloudflared tunnel create` or shown in the
# Cloudflare Zero Trust dashboard. Route the tunnel to http://caddy:8080.
CLOUDFLARE_TUNNEL_TOKEN=

# ---------- Tailscale Funnel (prod, optional) ----------
# Reusable ephemeral auth key from https://login.tailscale.com.
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=vibept

# ---------- Payroll exports ----------
# Where generated payroll CSVs land. The directory is created on demand.
EXPORTS_DIR=./exports

# ---------- EmailIt (appliance-wide fallback) ----------
# Companies can override these per-company in their settings. Leave
# blank to make email opt-in only — no email is sent until at least
# a company or the appliance has EMAILIT_API_KEY + EMAILIT_FROM_EMAIL
# configured.
EMAILIT_API_KEY=
EMAILIT_FROM_EMAIL=
EMAILIT_FROM_NAME=Vibe Payroll Time
EMAILIT_API_BASE_URL=https://api.emailit.com/v2

# Set to "true" in dev/test to stub notifications. Only affects
# background/automated sends (missed-punch reminders, approval
# deadlines) — interactive sends (magic-link, password reset, phone
# verification) bypass the flag because suppressing them looks like a
# broken button to the user. Log rows still land with a 'disabled'
# status so the admin UI reflects the skipped send.
NOTIFICATIONS_DISABLED=false

# ---------- AI / LLM (appliance-wide fallback) ----------
# Companies can override per-company. Leave blank to make AI opt-in.
# Phase 14 rename: LLM_API_KEY / LLM_MODEL / LLM_ENDPOINT are the
# canonical names; legacy AI_API_KEY / AI_MODEL / AI_BASE_URL still
# work and emit a single [deprecated] log line at boot. The provider
# default keeps the AI_PROVIDER_DEFAULT name for now.
# Provider: anthropic | openai_compatible | ollama (default anthropic)
AI_PROVIDER_DEFAULT=anthropic
LLM_API_KEY=
# Optional explicit model id (e.g. "claude-opus-4-7", "gpt-4o-mini")
LLM_MODEL=
# Optional base URL override for openai_compatible / self-hosted ollama
LLM_ENDPOINT=

# ---------- SMS (appliance-wide fallback) ----------
# When the appliance_settings row has no sms_provider, this env value
# is used. Accepted: twilio | textlinksms | textlink | none. The
# `textlink` short form is normalized to textlinksms internally.
# Per-provider creds (TWILIO_*, TEXTLINKSMS_*) are configured per-
# company in the admin UI, not via env.
SMS_PROVIDER=none

# ---------- Licensing (Phase 12) ----------
# Master switch. Leave false while the appliance is pre-live — the
# enforcement middleware short-circuits every request to pass. Flip to
# true once a license is loaded and the portal is reachable.
LICENSING_ENFORCED=false

# Optional overrides. In dev the bundled dev public key is used; in
# prod the installer pins these to the current kisaes-license-portal
# release.
LICENSE_PUBKEY_PEM=
LICENSE_PORTAL_HEARTBEAT_URL=

# ---------- Backup (prod) ----------
# Override the default rotating backup retention window (days).
RETENTION_DAYS=14

# ---------- Image metadata (prod, set by CI) ----------
APP_VERSION=0.0.0
GIT_SHA=unknown
BUILD_DATE=unknown
IMAGE_TAG=latest
