{
  "name": "@vibept/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "knex --knexfile ./knexfile.cjs migrate:latest",
    "migrate:make": "knex --knexfile ./knexfile.cjs migrate:make",
    "migrate:rollback": "knex --knexfile ./knexfile.cjs migrate:rollback",
    "migrate:status": "knex --knexfile ./knexfile.cjs migrate:status",
    "seed:make": "knex --knexfile ./knexfile.cjs seed:make",
    "seed:run": "knex --knexfile ./knexfile.cjs seed:run",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@vibept/shared": "*",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cors": "^2.8.5",
    "dotenv-flow": "^4.1.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "otplib": "^12.0.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.19.2",
    "twilio": "^5.3.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
